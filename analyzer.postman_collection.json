{
  "info": {
    "_postman_id": "github-profile-analyzer-v1",
    "name": "GitHub Profile Analyzer API",
    "description": "Complete API collection for the GitHub Profile Analyzer backend service.\n\n## Setup\n1. Import this collection into Postman\n2. Set the `base_url` variable to your deployed URL or `http://localhost:3000`\n3. Run **Analyze Profile** first before calling GET endpoints\n\n## Base URL Variable\n- Local: `http://localhost:3000`\n- Deployed: your Railway/Render URL",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000",
      "type": "string",
      "description": "Change this to your deployed URL"
    },
    {
      "key": "username",
      "value": "torvalds",
      "type": "string",
      "description": "GitHub username to analyze"
    }
  ],
  "item": [
    {
      "name": " Health & Info",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/health",
              "host": ["{{base_url}}"],
              "path": ["health"]
            },
            "description": "Check if the API server is running and healthy."
          },
          "response": [
            {
              "name": "200 OK",
              "originalRequest": {
                "method": "GET",
                "url": { "raw": "{{base_url}}/health" }
              },
              "status": "OK",
              "code": 200,
              "body": "{\n  \"status\": \"ok\",\n  \"service\": \"github-profile-analyzer\",\n  \"timestamp\": \"2025-01-01T00:00:00.000Z\",\n  \"environment\": \"development\"\n}"
            }
          ]
        },
        {
          "name": "API Root — Endpoint Directory",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/",
              "host": ["{{base_url}}"],
              "path": [""]
            },
            "description": "Returns a directory of all available API endpoints."
          },
          "response": []
        }
      ]
    },
    {
      "name": " Analyze",
      "item": [
        {
          "name": "Analyze GitHub Profile",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/api/analyze/{{username}}",
              "host": ["{{base_url}}"],
              "path": ["api", "analyze", "{{username}}"]
            },
            "description": "Fetches a GitHub user's public profile and all repositories, computes insights (stars, forks, language breakdown, activity score, account age), and stores/refreshes the record in MySQL.\n\n**Returns 201** on first analysis, **200** on refresh.\n\n**Rate limit:** 10 requests/minute"
          },
          "response": [
            {
              "name": "201 Created - New Profile",
              "originalRequest": {
                "method": "POST",
                "url": { "raw": "{{base_url}}/api/analyze/torvalds" }
              },
              "status": "Created",
              "code": 201,
              "body": "{\n  \"success\": true,\n  \"message\": \"Profile analyzed and stored.\",\n  \"data\": {\n    \"id\": 1,\n    \"github_id\": 1024025,\n    \"username\": \"torvalds\",\n    \"display_name\": \"Linus Torvalds\",\n    \"bio\": null,\n    \"company\": \"Linux Foundation\",\n    \"location\": \"Portland, OR\",\n    \"email\": null,\n    \"blog_url\": null,\n    \"twitter_handle\": null,\n    \"avatar_url\": \"https://avatars.githubusercontent.com/u/1024025\",\n    \"github_url\": \"https://github.com/torvalds\",\n    \"account_type\": \"User\",\n    \"public_repos\": 8,\n    \"public_gists\": 0,\n    \"followers\": 236000,\n    \"following\": 0,\n    \"total_stars\": 195000,\n    \"total_forks\": 56000,\n    \"total_watchers\": 195000,\n    \"account_age_days\": 5670,\n    \"activity_score\": 95.47,\n    \"hireable\": 0,\n    \"github_created_at\": \"2011-09-03T15:26:22.000Z\",\n    \"github_updated_at\": \"2024-01-01T00:00:00.000Z\",\n    \"created_at\": \"2025-01-01T00:00:00.000Z\",\n    \"last_analyzed_at\": \"2025-01-01T00:00:00.000Z\",\n    \"top_repositories\": [\n      {\n        \"repo_name\": \"linux\",\n        \"full_name\": \"torvalds/linux\",\n        \"description\": \"Linux kernel source tree\",\n        \"language\": \"C\",\n        \"stars\": 185000,\n        \"forks\": 55000,\n        \"watchers\": 185000,\n        \"open_issues\": 0,\n        \"is_fork\": 0,\n        \"repo_url\": \"https://github.com/torvalds/linux\",\n        \"created_at\": \"2011-09-04T22:48:12.000Z\"\n      }\n    ],\n    \"languages\": [\n      { \"language\": \"C\", \"repo_count\": 3, \"percentage\": 60.00 },\n      { \"language\": \"Python\", \"repo_count\": 2, \"percentage\": 40.00 }\n    ]\n  }\n}"
            },
            {
              "name": "404 Not Found",
              "originalRequest": {
                "method": "POST",
                "url": { "raw": "{{base_url}}/api/analyze/this-user-does-not-exist-xyz" }
              },
              "status": "Not Found",
              "code": 404,
              "body": "{\n  \"success\": false,\n  \"message\": \"GitHub user 'this-user-does-not-exist-xyz' not found.\"\n}"
            },
            {
              "name": "400 Bad Request - Invalid Username",
              "originalRequest": {
                "method": "POST",
                "url": { "raw": "{{base_url}}/api/analyze/invalid username!" }
              },
              "status": "Bad Request",
              "code": 400,
              "body": "{\n  \"success\": false,\n  \"message\": \"Invalid GitHub username format.\"\n}"
            }
          ]
        },
        {
          "name": "Analyze - Popular Devs (Batch Examples)",
          "item": [
            {
              "name": "Analyze: gaearon (Dan Abramov)",
              "request": {
                "method": "POST",
                "header": [],
                "url": {
                  "raw": "{{base_url}}/api/analyze/gaearon",
                  "host": ["{{base_url}}"],
                  "path": ["api", "analyze", "gaearon"]
                }
              },
              "response": []
            },
            {
              "name": "Analyze: sindresorhus",
              "request": {
                "method": "POST",
                "header": [],
                "url": {
                  "raw": "{{base_url}}/api/analyze/sindresorhus",
                  "host": ["{{base_url}}"],
