              "path": ["api", "profiles"],
              "query": [
                { "key": "sort", "value": "followers" },
                { "key": "order", "value": "desc" }
              ]
            }
          },
          "response": []
        },
        {
          "name": "List Profiles — Sort by Activity Score",
          "request": {
            "method": "GET",
