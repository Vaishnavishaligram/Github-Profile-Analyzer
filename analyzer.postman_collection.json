        {
          "name": "List Profiles — Paginated",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/profiles?page=2&limit=5",
              "host": ["{{base_url}}"],
              "path": ["api", "profiles"],
              "query": [
                { "key": "page", "value": "2" },
                { "key": "limit", "value": "5" }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get Single Profile",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/profiles/{{username}}",
              "host": ["{{base_url}}"],
              "path": ["api", "profiles", "{{username}}"]
            },
            "description": "Returns the full stored profile including top repositories and language breakdown. Run Analyze first."
          },
          "response": [
            {
              "name": "200 OK — Full Profile",
              "originalRequest": {
                "method": "GET",
                "url": { "raw": "{{base_url}}/api/profiles/torvalds" }
              },
              "status": "OK",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"data\": {\n    \"id\": 1,\n    \"username\": \"torvalds\",\n    \"display_name\": \"Linus Torvalds\",\n    \"followers\": 236000,\n    \"total_stars\": 195000,\n    \"activity_score\": 95.47,\n    \"top_repositories\": [...],\n    \"languages\": [...]\n  }\n}"
            },
            {
              "name": "404 Not Found",
              "status": "Not Found",
              "code": 404,
              "body": "{\n  \"success\": false,\n  \"message\": \"Profile 'unknownuser' not found. Use POST /api/analyze/unknownuser to analyze it first.\"\n}"
            }
          ]
        },
        {
          "name": "Delete Profile",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/profiles/{{username}}",
              "host": ["{{base_url}}"],
              "path": ["api", "profiles", "{{username}}"]
            },
            "description": "Permanently deletes the stored profile and all associated repositories and language data."
          },
          "response": [
            {
              "name": "200 OK — Deleted",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"message\": \"Profile 'torvalds' deleted successfully.\"\n}"
            }
          ]
        }
      ]
    },
