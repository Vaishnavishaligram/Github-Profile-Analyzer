                }
              },
              "response": []
            },
            {
              "name": "Analyze: yyx990803 (Evan You)",
              "request": {
                "method": "POST",
                "header": [],
                "url": {
                  "raw": "{{base_url}}/api/analyze/yyx990803",
                  "host": ["{{base_url}}"],
                  "path": ["api", "analyze", "yyx990803"]
                }
              },
              "response": []
            }
          ]
        }
      ]
    },
    {
      "name": " Profiles",
      "item": [
        {
          "name": "List All Profiles (Default)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/profiles",
              "host": ["{{base_url}}"],
              "path": ["api", "profiles"]
            },
            "description": "Returns all stored profiles with pagination. Default: page 1, 20 per page, sorted by last_analyzed_at DESC."
          },
          "response": []
        },
        {
          "name": "List Profiles — Sort by Stars",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/profiles?sort=total_stars&order=desc&limit=10",
              "host": ["{{base_url}}"],
              "path": ["api", "profiles"],
              "query": [
                { "key": "sort", "value": "total_stars" },
                { "key": "order", "value": "desc" },
                { "key": "limit", "value": "10" }
              ]
            },
            "description": "Top profiles sorted by total GitHub stars."
          },
          "response": []
        },
